{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/jira/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/jira/(.*)", "destination": "/api/jira/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
